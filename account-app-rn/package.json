{
  "name": "AccountApp",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.8.2",
  "engines": {
    "node": ">=20.20.0 <21",
    "npm": ">=10.8.2 <11"
  },
  "overrides": {
    "dayjs": "$dayjs",
    "react": "$react",
    "typescript": "$typescript"
  },
  "scripts": {
    "android": "react-native run-android",
    "android:assemble": "cd android && ./gradlew assembleDebug",
    "android:release": "cd android && ./gradlew clean assembleRelease",
    "ios": "react-native run-ios",
    "ios:sim": "react-native run-ios --simulator \"iPhone 17\" --no-packager",
    "ios:pods": "cd ios && bundle exec pod install",
    "start": "react-native start",
    "start:ios": "react-native start",
    "bundle:ios": "CI=1 react-native bundle --platform ios --dev false --entry-file index.js --bundle-output ios/main.jsbundle --assets-dest ios",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "jest"
  },
  "dependencies": {
    "@hookform/resolvers": "^4.1.0",
    "@react-native-async-storage/async-storage": "^2.1.0",
    "@react-navigation/bottom-tabs": "7.2.0",
    "@react-navigation/native": "7.2.2",
    "@react-navigation/native-stack": "7.2.0",
    "@wuba/react-native-echarts": "^3.0.1",
    "dayjs": "^1.11.13",
    "echarts": "^6.0.0",
    "react": "18.3.1",
    "react-hook-form": "^7.55.0",
    "react-native": "0.76.7",
    "react-native-gesture-handler": "2.21.2",
    "react-native-haptic-feedback": "^3.0.0",
    "react-native-paper": "5.13.1",
    "react-native-safe-area-context": "4.14.0",
    "react-native-screens": "4.5.0",
    "react-native-svg": "^15.15.4",
    "react-native-vector-icons": "10.2.0",
    "yup": "^1.6.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@babel/runtime": "^7.26.0",
    "@react-native-community/cli": "15.0.1",
    "@react-native-community/cli-platform-android": "15.0.1",
    "@react-native-community/cli-platform-ios": "15.0.1",
    "@react-native/babel-preset": "0.76.7",
    "@react-native/eslint-config": "0.76.7",
    "@react-native/metro-config": "0.76.7",
    "@react-native/typescript-config": "0.76.7",
    "@types/jest": "^29.5.13",
    "@types/react": "^18.3.12",
    "@types/react-test-renderer": "^18.3.0",
    "babel-jest": "^29.7.0",
    "babel-plugin-module-resolver": "^5.0.2",
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "prettier": "^3.4.2",
    "react-test-renderer": "18.3.1",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=18"
  }
}
