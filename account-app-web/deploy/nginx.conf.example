server {
  listen 80;
  server_name _;

  root /var/www/account-app-web;
  index index.html;

  # SPA fallback
  location / {
    try_files $uri $uri/ /index.html;
  }

  # Hashed static assets: strong cache
  location /assets/ {
    expires 1y;
    add_header Cache-Control "public, max-age=31536000, immutable" always;
    try_files $uri =404;
  }

  # HTML entry: avoid aggressive cache
  location = /index.html {
    add_header Cache-Control "no-cache" always;
  }

  # gzip (fallback)
  gzip on;
  gzip_vary on;
  gzip_min_length 1024;
  gzip_types
    text/plain
    text/css
    application/javascript
    application/json
    application/xml
    image/svg+xml;

  # brotli (requires ngx_brotli)
  brotli on;
  brotli_comp_level 5;
  brotli_min_length 1024;
  brotli_types
    text/plain
    text/css
    application/javascript
    application/json
    application/xml
    image/svg+xml;

  # Prefer precompressed files generated by Vite build plugins
  gzip_static on;
  brotli_static on;
}
