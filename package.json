{
  "name": "app-demo",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.8.2",
  "engines": {
    "node": ">=20.20.0 <21",
    "npm": ">=10.8.2 <11"
  },
  "overrides": {
    "dayjs": "1.11.13",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "typescript": "5.7.3",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1"
  },
  "scripts": {
    "bootstrap": "npm run install:all",
    "install:all": "npm ci --prefix account-app-rn && npm ci --prefix account-app-mp && npm ci --prefix account-app-shared && npm ci --prefix account-app-web",
    "dev:rn": "npm run start:ios --prefix account-app-rn",
    "dev:mp": "npm run dev:weapp --prefix account-app-mp",
    "dev:web": "npm run dev --prefix account-app-web",
    "build:mp": "npm run build:weapp --prefix account-app-mp",
    "build:web": "npm run build --prefix account-app-web",
    "report:web": "npm run build:report --prefix account-app-web",
    "typecheck:rn": "npm run typecheck --prefix account-app-rn",
    "typecheck:web": "npm run typecheck --prefix account-app-web",
    "postinstall": "npm run bootstrap"
  }
}
