{
  "name": "account-app-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@10.8.2",
  "engines": {
    "node": ">=20.20.0 <21",
    "npm": ">=10.8.2 <11"
  },
  "overrides": {
    "dayjs": "$dayjs",
    "react": "$react",
    "react-dom": "$react-dom",
    "typescript": "$typescript"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "check:budget": "node scripts/check-bundle-budget.mjs",
    "report:bundle": "node scripts/bundle-report.mjs",
    "build:report": "npm run build && npm run check:budget && npm run report:bundle",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "account-app-shared": "file:../account-app-shared",
    "dayjs": "^1.11.13",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.7.3",
    "vite": "^6.2.0",
    "vite-plugin-compression": "^0.5.1"
  }
}
